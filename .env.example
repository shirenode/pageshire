# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Supabase (required for sign-in) ---
# From: Supabase dashboard -> your project -> Settings -> API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# --- Paywall ---
# Number of free merges/conversions before the paywall appears.
FREE_MERGE_LIMIT=1
# Rolling window in hours after which free usage resets.
USAGE_WINDOW_HOURS=24
# URL the "Upgrade to Pro" button opens (e.g. a Stripe Checkout / payment link).
UPGRADE_URL=

# --- Limits (security: prevent PDF bombs) ---
MAX_FILE_BYTES=52428800        # 50 MB per file
MAX_TOTAL_BYTES=209715200      # 200 MB per request
MAX_FILES=50                   # max files per request
MAX_PAGES_PER_FILE=2000        # reject single PDFs over this many pages
MAX_PAGES_PER_REQUEST=5000     # reject combined page counts over this

# --- Server ---
PORT=3000
